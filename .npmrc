# React and Next are peerDependencies, provided by the consuming app — do NOT let
# npm auto-install them into this library's node_modules. A linked/`file:` install
# of this package resolves through its real directory, so a second copy of React
# nested here gets bundled into the consumer's build alongside the app's own React
# and breaks it (e.g. Next App Router client-component prerender: "Cannot read
# properties of null (reading 'useContext')"). The build externalizes react; the
# jsdom mount test imports react/react-dom, so they (with @types/react and
# @types/react-dom for the types) are devDependencies here. `legacy-peer-deps`
# keeps npm from auto-installing the react/next peers nested in this package.
legacy-peer-deps=true
